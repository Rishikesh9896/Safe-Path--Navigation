<!DOCTYPE html>
<html>
<head>
    <title>Crime Statistics - Etihaad</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
        }
        .container {
            max-width: 1000px;
            margin: 0 auto;
            background: white;
            border-radius: 10px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.2);
            padding: 40px;
        }
        h1 {
            color: #333;
            text-align: center;
            margin-bottom: 10px;
            font-size: 2.5em;
        }
        .subtitle {
            text-align: center;
            color: #666;
            margin-bottom: 40px;
            font-size: 1.1em;
        }
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 40px;
        }
        .stat-card {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 30px;
            border-radius: 10px;
            text-align: center;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
            transition: transform 0.3s ease;
        }
        .stat-card:hover {
            transform: translateY(-5px);
        }
        .stat-card h3 {
            font-size: 0.9em;
            opacity: 0.9;
            margin-bottom: 10px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        .stat-card .number {
            font-size: 3em;
            font-weight: bold;
            display: block;
        }
        .mag-0 { background: linear-gradient(135deg, #84fab0 0%, #8fd3f4 100%); }
        .mag-1 { background: linear-gradient(135deg, #fa709a 0%, #fee140 100%); }
        .mag-2 { background: linear-gradient(135deg, #30cfd0 0%, #330867 100%); }
        .mag-3 { background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%); color: #333; }
        .mag-4 { background: linear-gradient(135deg, #ff9a56 0%, #ff6a88 100%); }
        
        .button-group {
            text-align: center;
            margin-top: 30px;
        }
        .btn {
            display: inline-block;
            padding: 12px 30px;
            margin: 5px;
            background: #667eea;
            color: white;
            text-decoration: none;
            border-radius: 5px;
            transition: background 0.3s ease;
            border: none;
            cursor: pointer;
            font-size: 1em;
        }
        .btn:hover {
            background: #764ba2;
        }
        .total-crimes {
            background: #f5f5f5;
            padding: 20px;
            border-radius: 10px;
            text-align: center;
            margin-top: 30px;
            border-left: 5px solid #667eea;
        }
        .total-crimes h2 {
            color: #667eea;
            margin-bottom: 10px;
        }
        .total-crimes p {
            font-size: 2em;
            color: #333;
            font-weight: bold;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>📊 Crime Statistics</h1>
        <p class="subtitle">Delhi Crime Magnitude Distribution</p>
        
        <div class="stats-grid">
            <div class="stat-card mag-0">
                <h3>Magnitude 0</h3>
                <span class="number"><%= stats[0] %></span>
                <p>Incidents</p>
            </div>
            <div class="stat-card mag-1">
                <h3>Magnitude 1</h3>
                <span class="number"><%= stats[1] %></span>
                <p>Incidents</p>
            </div>
            <div class="stat-card mag-2">
                <h3>Magnitude 2</h3>
                <span class="number"><%= stats[2] %></span>
                <p>Incidents</p>
            </div>
            <div class="stat-card mag-3">
                <h3>Magnitude 3</h3>
                <span class="number"><%= stats[3] %></span>
                <p>Incidents</p>
            </div>
            <div class="stat-card mag-4">
                <h3>Magnitude 4</h3>
                <span class="number"><%= stats[4] %></span>
                <p>Incidents</p>
            </div>
        </div>

        <div class="total-crimes">
            <h2>📍 Total Crimes Recorded</h2>
            <p><%= stats[0] + stats[1] + stats[2] + stats[3] + stats[4] %></p>
        </div>

        <div class="button-group">
            <a href="/maps" class="btn">🗺️ View Map</a>
            <a href="/" class="btn">🏠 Home</a>
        </div>
    </div>
</body>
</html>
